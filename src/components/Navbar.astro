---
const navLinks = [
  { name: "Inicio", href: "#Home" },
  { name: "Nuestras Soluciones", href: "#Products" },
  { name: "Software a Medida", href: "#Software" },
  { name: "Por Qué Elegirnos?", href: "#About" },
  { name: "Contáctanos", href: "#Contacto" },
];
const currentPath = Astro.url.pathname;
---

<nav class="container-nav">
  <div class="logo">
    <a href="#Home">
      <img src="/images/logo-tm.jpeg" alt="Logo" width="60" height="60" />
    </a>
  </div>

  <input type="checkbox" id="menu-toggle" class="menu-toggle" />
  <label for="menu-toggle" class="menu-icon">&#9776;</label>

  <ul class="navbar-list">
    {
      navLinks.map((link) => (
        <li class="navbar-item">
          <a href={link.href} class={currentPath === link.href ? "active" : ""}>
            {link.name}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .logo img {
    border-radius: 50%;
    transition: transform 0.3s;
  }
  .container-nav {
    background-color: var(--azul-profundo);
    position: fixed;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    font-family: "Montserrat", sans-serif;
    z-index: 10000;
    box-shadow: 0px 1px 10px rgba(0, 0, 0, 0.3);
  }

  .navbar-list {
    list-style: none;
    display: flex;
    gap: 30px;
    margin: 0 auto;
    padding: 0;
    width: 80%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .navbar-item a {
    color: white;
    text-decoration: none;
    font-size: 1.1rem;
    transition: all 0.5s;
  }

  .navbar-item a:hover {
    color: var(--lemon-tonic);
    text-decoration: underline;
  }

  .navbar-item a.active {
    color: var(--lemon-tonic);
    font-weight: bold;
    border-bottom: 2px solid var(--lemon-tonic);
  }

  .menu-toggle {
    display: none;
  }

  .menu-icon {
    display: none;
    font-size: 2rem;
    cursor: pointer;
    color: white;
  }

  @media (max-width: 768px) {
    .navbar-list {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 60px;
      left: 0;
      width: 100%;
      background-color: var(--azul-profundo);
      text-align: center;
      padding: 1rem 0;
    }

    .menu-icon {
      display: block;
    }

    .menu-toggle:checked + .menu-icon + .navbar-list {
      display: flex;
    }
  }
</style>
