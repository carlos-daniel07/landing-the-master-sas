---
import Terms from "./legal/Terms.astro";
import Contact from "./Contact.astro";
---

<footer>
  <div class="logo-footer">
    <a
      href="https://themasterssas.com/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        src="/images/logo-tm-removebg.png"
        alt="The Mastersas Logo"
        width="180"
        height="180"
      />
    </a>
  </div>
  <div class="container-footer">
    <div class="us">
      <h4>Nosotros</h4>
      <a href="#Home">Quiénes Somos</a>
      <a href="">Nuestro Equipo</a>
      <a href="#Contacto">Trabaja con nosotros</a>
    </div>

    <div class="legal">
      <h4>Legal</h4>
      <button class="btn-legal" onclick="abrirModal('terms')"
        >Términos y condiciones</button
      >
      <button class="btn-legal" onclick="abrirModal('privacy')"
        >Política de privacidad</button
      >
      <button class="btn-legal" onclick="abrirModal('retracto')"
        >Derecho de retracto</button
      >
      <a href=""> SIC</a>
    </div>

    <div class="contact">
      <h4>Contacto</h4>
      <p>Dirección: Cra 37 # 38 A sur 50 apt 201, Envigado</p>
      <p>Teléfono: +57 300 123 4567</p>
      <p>Correo: corporate@themasterssas.com</p>
    </div>
  </div>
  <div class="social-media">
    <p>&copy;2026 The Master SAS. Todos los derechos reservados.</p>
    <p>NIT: 901397481-1</p>
    <div>
      <a
        href="https://www.facebook.com/themasterssas"
        target="_blank"
        rel="noopener noreferrer"><i class="bx bxl-facebook-circle"></i></a
      >
      <a
        href="https://www.linkedin.com/company/themasterssas"
        target="_blank"
        rel="noopener noreferrer"><i class="bx bxl-linkedin-square"></i></a
      >
      <a
        href="https://www.instagram.com/themasterssas"
        target="_blank"
        rel="noopener noreferrer"><i class="bx bxl-instagram-alt"></i></a
      >
    </div>
  </div>
</footer>

<dialog id="miModalLegal">
  <div class="modal-contenido">
    <div class="modal-header">
      <h3 id="titulo-modal">Información</h3>
      <button onclick="cerrarModal()" class="btn-cerrar">&times;</button>
    </div>

    <div class="modal-body">
      <div id="texto-terms" class="texto-oculto" style="display:none;">
        <p>
          <strong>1. Aceptación:</strong> Al usar este sitio aceptas nuestros términos.
        </p>
        <p>
          <strong>2. Uso:</strong> No puedes copiar nuestro contenido sin permiso.
        </p>
        <p>TERMINOS...</p>
      </div>

      <div id="texto-privacy" class="texto-oculto" style="display:none;">
        <p>
          <strong>Tus datos:</strong> Protegemos tu información según la Ley 1581.
        </p>
        <p>POLÍTICA DE PRIVACIDAD...</p>
      </div>

      <div id="texto-retracto" class="texto-oculto" style="display:none;">
        <p>
          Tienes 5 días hábiles para devolver tu compra si no estás satisfecho.
        </p>
        <p>RETRACTO...</p>
      </div>
    </div>
  </div>
</dialog>

<style>
  footer {
    background-color: var(--azul-profundo);
    font-family: "Montserrat", sans-serif;
    padding-bottom: 2.5rem;
    width: 100%;
    margin: 0 auto;
  }
  .logo-footer {
    /* background-color: red; */
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .logo-footer img {
    background-color: var(--azul-palido);
    border-radius: 0px 0px 15px 15px;
    padding: 0;
    margin: 0;
    display: block;
  }
  .container-footer {
    /* background-color: green; */
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem 1.3rem;
    color: var(--azul-palido);
    text-align: center;
    align-items: center;
  }
  .container-footer h4 {
    font-size: 1.3rem;
    margin-bottom: 0.3rem;
    color: var(--amarillo-aburrido);
  }

  .us a,
  .legal button,
  .legal a,
  .contact p {
    background-color: transparent;
    border: none;
    font-size: 1rem;
    text-decoration: none;
    color: var(--azul-palido);
    transition: all 0.3s ease;
    line-height: 1.6;
    text-align: center;
    cursor: pointer;
  }

  .us a:hover,
  .legal button:hover,
  .legal a:hover {
    color: var(--lemon-tonic);
    text-decoration: underline;
  }

  .us,
  .legal,
  .contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .social-media {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    padding: 1.3rem;
    text-align: center;
    color: var(--azul-palido);
    font-size: 0.9rem;
    gap: 0.5rem;
  }

  .social-media p {
    font-size: 1rem;
  }

  .social-media a {
    color: var(--azul-palido);
    text-decoration: none;
    width: fit-content;
    margin: 0 10px;
    font-weight: bold;
    font-size: 2.5rem;
    transition: all 0.4s;
  }

  .social-media a:hover {
    display: inline-block;
    color: var(--amarillo-aburrido);
    text-decoration: underline;
    transform: translateY(-3px) scale(1.1);
  }

  .social-media a:active {
    transform: translateY(0) scale(0.98);
  }

  @media (min-width: 768px) {
    .container-footer {
      flex-direction: row;
      justify-content: center;
      gap: 5rem;
      text-align: left;
      align-items: flex-start;
    }

    .us a,
    .legal button,
    .legal a,
    .contact p {
      text-align: left;
    }
  }

  /* --- ESTILOS DEL MODAL (VENTANA) --- */
  dialog {
    border: none;
    border-radius: 10px;
    padding: 0;
    width: 90%;
    max-width: 600px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    margin: 0 auto;
    margin-top: 1rem;
  }
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
  }

  .modal-header {
    background: var(--azul-profundo);
    color: var(--azul-palido);
    padding: 15px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #ccc;
    font-family: "Montserrat", sans-serif;
  }
  .modal-header h3 {
    margin: 0;
    color: var(--azul-palido);
  }
  .btn-cerrar {
    font-size: 2rem;
    cursor: pointer;
    border: none;
    background: none;
    line-height: 1;
    background: transparent;
    color: var(--azul-palido);
  }

  .modal-body {
    font-family: "Montserrat", sans-serif;
    background-color: var(--azul-palido);
    padding: 20px;
    max-height: 70vh;
    overflow-y: auto;
    color: var(--azul-marino);
    text-align: left;
    line-height: 1.6;
  }

  .modal-body strong {
    color: var(--azul-profundo);
  }
</style>

<script is:inline>
  function abrirModal(tipo) {
    const modal = document.getElementById("miModalLegal");
    const titulo = document.getElementById("titulo-modal");

    // 1. Ocultamos todos los textos
    document.getElementById("texto-terms").style.display = "none";
    document.getElementById("texto-privacy").style.display = "none";
    document.getElementById("texto-retracto").style.display = "none";

    // 2. Mostramos solo el que diste click y cambiamos título
    if (tipo === "terms") {
      titulo.innerText = "Términos y Condiciones";
      document.getElementById("texto-terms").style.display = "block";
    } else if (tipo === "privacy") {
      titulo.innerText = "Política de Privacidad";
      document.getElementById("texto-privacy").style.display = "block";
    } else if (tipo === "retracto") {
      titulo.innerText = "Derecho de Retracto";
      document.getElementById("texto-retracto").style.display = "block";
    }

    // 3. Abrimos el modal
    modal.showModal();
    document.body.style.overflow = "hidden"; // Bloquea el scroll de fondo
  }

  function cerrarModal() {
    const modal = document.getElementById("miModalLegal");
    modal.close();
    document.body.style.overflow = "";
  }

  // Cerrar si das click afuera
  document.getElementById("miModalLegal").addEventListener("click", (e) => {
    if (e.target === document.getElementById("miModalLegal")) {
      cerrarModal();
    }
  });
</script>
