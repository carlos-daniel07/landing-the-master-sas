<style>
  .container {
    font-family: "Montserrat", sans-serif;
    width: 90%;
    /* height: 100%; */
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
    padding: 1rem 0rem;
    text-align: left;
    overflow: hidden;
    position: relative;
  }

  .container h1 {
    font-size: 2.5rem;
    color: var(--azul-profundo);
    margin-top: 3rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .plataforms-container {
    /* display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: rgb(215, 238, 10); */
  }
  .plataform-card {
    background-color: var(--azul-palido);
    margin: 1rem 0;
    padding: 1.5rem 2rem;
    width: 90%;
    /* height: 550px; */
    max-width: 600px;
    border-radius: 8%;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
  }
  .plataform-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
  }

  .plataform-icon {
    margin-bottom: 0.6rem;
  }

  .plataform-card h2 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }

  .plataform-card p {
    font-size: 1.1rem;
    color: var(--azul-marino);
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .plataform-card pre {
    font-family: "Montserrat", sans-serif;
    font-size: 1.1rem;
    color: var(--azul-marino);
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .plataform-card a {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    font-size: 1.2rem;
    text-decoration: none;
    font-weight: 500;
    border-radius: 50px;
    border: 2px solid var(--azul-brillante);
    background-color: transparent;
    color: var(--azul-brillante);
    box-shadow: 0 0 6px rgba(29, 120, 156, 0.5);
    margin-bottom: 0.5rem;
    transition: all 0.3s;
  }

  .plataform-card a:hover {
    background-color: var(--hover-color);
    border-color: var(--hover-color);
    box-shadow: 0 0 6px var(--hover-color);
    color: var(--azul-palido);
    transform: translateY(-2px);
    text-decoration: underline;
  }

  .plataform-card a:active {
    transform: scale(0.99);
    box-shadow: 0 0 4px var(--hover-color);
  }

  /* Slider */

  .carousel {
    width: 100%;
    height: 75dvh;
    overflow: hidden;
    position: relative;
  }

  .carousel .list .item {
    position: absolute;
    inset: 0 0 0 0;
  }

  .carousel .list .item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .carousel .list .item .content {
    position: absolute;
    top: 20%;
    left: 50%;
    width: 1140px;
    max-width: 80%;
    transform: translateX(-50%);
    padding-right: 30%;
    box-sizing: border-box;
    color: var(--azul-palido);
    text-shadow: 0 5px 10px rgba(0, 0, 0, 0.5);
  }

  .carousel .list .item .content .title,
  .carousel .list .item .content .sub {
    font-size: 2em;
    font-weight: bold;
    list-style: 1.3em;
  }

  .carousel .list .item .content button {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    font-size: 1.2rem;
    text-decoration: none;
    font-weight: 600;
    border-radius: 50px;
    cursor: pointer;
    border: 2px solid var(--azul-brillante);
    background-color: transparent;
    color: var(--azul-brillante);
    box-shadow: 0 0 6px rgba(29, 120, 156, 0.5);
    margin-bottom: 0.5rem;
    margin-top: 1rem;
    letter-spacing: 2px;
    transition: all 0.3s;
  }

  .carousel .list .item .content button:hover {
    background-color: var(--lemon-tonic);
    border-color: var(--azul-profundo);
    box-shadow: 0 0 6px var(--azul-brillante);
    color: var(--azul-profundo);
    transform: translateY(-2px);
    text-decoration: underline;
  }

  .thumbnail {
    position: absolute;
    bottom: 50px;
    left: 50%;
    width: max-content;
    z-index: 1000;
    display: flex;
    gap: 20px;
    color: var(--azul-palido);
    text-shadow: 0 5px 10px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }

  .thumbnail .item {
    width: 150px;
    height: 220px;
    flex-shrink: 0;
    position: relative;
  }

  .thumbnail .item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
  }

  .thumbnail .item .content {
    position: absolute;
    bottom: 10px;
    left: 10px;
    right: 10px;
  }

  .thumbnail .item .content .title {
    font-weight: bold;
  }

  .arrows {
    position: absolute;
    top: 80%;
    right: 52%;
    width: 300px;
    max-width: 30%;
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .arrows button {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--azul-profundo);
    border: none;
    font-family: monospace;
    color: var(--azul-palido);
    font-weight: bold;
    font-size: large;
    transition: 0.5s;
    cursor: pointer;
    z-index: 1000;
  }

  .arrows button:hover {
    background-color: var(--azul-palido);
    color: var(--azul-profundo);
  }

  .carousel .list .item:nth-child(1) {
    z-index: 1;
  }

  .carousel .list .item:nth-child(1) .title,
  .carousel .list .item:nth-child(1) .sub,
  .carousel .list .item:nth-child(1) .des,
  .carousel .list .item:nth-child(1) .buttons {
    transform: translateY(50px);
    filter: blur(20px);
    opacity: 0;
    animation: showContent 0.3s 0.8s linear 1 forwards;
  }

  @keyframes showContent {
    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }
  .carousel .list .item:nth-child(1) .sub {
    animation-delay: 1s;
  }

  .carousel .list .item:nth-child(1) .des {
    animation-delay: 1.2s;
  }

  .carousel .list .item:nth-child(1) .buttons {
    animation-delay: 1.4s;
  }

  .carousel.next .list .item:nth-child(1) img {
    width: 150px;
    height: 220px;
    position: absolute;
    left: 50%;
    bottom: 50px;
    border-radius: 20px;
    animation: showImage 0.5s linear 1 forwards;
  }

  @keyframes showImage {
    to {
      width: 100%;
      height: 100%;
      left: 0;
      bottom: 0;
      border-radius: 0;
    }
  }

  .carousel.next .thumbnail .item:nth-last-child(1) {
    width: 0;
    overflow: hidden;
    animation: showThumbnail 0.5s linear 1 forwards;
  }

  @keyframes showThumbnail {
    to {
      width: 150px;
      opacity: 1;
    }
  }

  .carousel.next .thumbnail {
    transform: translateX(170px);
    animation: transformThumbnail 0.5s linear 1 forwards;
  }

  @keyframes transformThumbnail {
    from {
      transform: translateX(170px);
    }
    to {
      transform: translateX(0);
    }
  }

  .carousel.prev .list .item:nth-child(2) {
    z-index: 2;
  }

  .carousel.prev .list .item:nth-child(2) img {
    position: absolute;
    bottom: 0;
    left: 0;
    animation: outImage 0.5s linear 1 forwards;
  }

  @keyframes outImage {
    to {
      width: 150px;
      height: 220px;
      left: 50%;
      bottom: 50px;
      border-radius: 20px;
      opacity: 0;
    }
  }

  .carousel.prev .thumbnail .item:nth-child(1) {
    width: 0;
    opacity: 0;
    overflow: hidden;
    animation: showThumbnail 0.5s linear 1 forwards;
  }

  .carousel.prev .list .item:nth-child(2) .title,
  .carousel.prev .list .item:nth-child(2) .sub,
  .carousel.prev .list .item:nth-child(2) .des,
  .carousel.prev .list .item:nth-child(2) .buttons {
    animation: contentOut 1.4s linear 1 forwards;
  }

  @keyframes contentOut {
    to {
      opacity: 0;
      filter: blur(20px);
      transform: translateY(-150px);
    }
  }

  .carousel.next .arrows button,
  .carousel.prev .arrows button {
    pointer-events: none;
  }

  @media screen and (max-width: 678px) {
    .carousel .list .item .content {
      padding-right: 0;
    }

    .carousel .list .item .content .title,
    .carousel .list .item .content .sub {
      font-size: 30px;
    }
  }
</style>

<script>
  let nextDom = document.getElementById("next");
  let prevDom = document.getElementById("prev");
  let carouselDom = document.querySelector(".carousel");
  let listItemDom = document.querySelector(".carousel .list");
  let thumbnailDom = document.querySelector(".carousel .thumbnail");

  if (nextDom) {
    nextDom.onclick = () => {
      showSlider("next");
    };
  }

  if (prevDom) {
    prevDom.onclick = () => {
      showSlider("prev");
    };
  }

  let timeRunning = 1000;
  let timeAutoNext = 10000;
  let runTimeOut: any;
  let runAutoNext: any = setTimeout(() => {
    nextDom?.click();
  }, timeAutoNext);

  function showSlider(type: any) {
    let itemSlider = document.querySelectorAll(".carousel .list .item");
    let thumbnailSlider = document.querySelectorAll(
      ".carousel .thumbnail .item",
    );

    if (type === "next") {
      listItemDom?.appendChild(itemSlider[0]);
      thumbnailDom?.appendChild(thumbnailSlider[0]);
      carouselDom?.classList.add("next");
    } else {
      let positionLastItem = itemSlider.length - 1;
      listItemDom?.prepend(itemSlider[positionLastItem]);
      thumbnailDom?.prepend(thumbnailSlider[positionLastItem]);
      carouselDom?.classList.add("prev");
    }

    clearTimeout(runTimeOut);
    runTimeOut = setTimeout(() => {
      carouselDom?.classList.remove("next");
      carouselDom?.classList.remove("prev");
    }, timeRunning);

    clearTimeout(runAutoNext);
    runAutoNext = setTimeout(() => {
      nextDom?.click();
    }, timeAutoNext);
  }
</script>
